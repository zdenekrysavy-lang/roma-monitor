# Zkopíruj na .env a vyplň. NIKDY necommituj .env s reálnými hodnotami.
# Potřeba jen pro REŽIM A (main.py) – režim B (gather.py) žádné klíče nepotřebuje.

# Anthropic API (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Volitelně: model (výchozí claude-sonnet-5; levnější: claude-haiku-4-5-20251001)
CLAUDE_MODEL=claude-sonnet-5

# E-mail
EMAIL_TO=zdenek.rysavy@romea.cz
EMAIL_FROM=monitoring@romea.cz
SMTP_HOST=smtp.romea.cz
SMTP_PORT=587
SMTP_USER=monitoring@romea.cz
SMTP_PASS=tajne-heslo

# Volitelné ladění (aktuální výchozí hodnoty)
LOOKBACK_HOURS=13
FEED_LOOKBACK_HOURS=72
MAX_CANDIDATES=300
GDELT_TIMESPAN=72h
GDELT_RETRIES=6
GN_PAUSE=2
